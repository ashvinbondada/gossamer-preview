{
  "name": "contexthtml",
  "displayName": "Clarity HTML",
  "description": "Automatically opens Simple Browser alongside any HTML file you open in Cursor",
  "version": "1.0.0",
  "publisher": "ashvinbondada",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:html"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "configuration": {
      "title": "ContextHTML",
      "properties": {
        "contexthtml.openEditor": {
          "type": "boolean",
          "default": false,
          "description": "Also open the HTML file in the text editor alongside Simple Browser. When false, only Simple Browser opens."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ashvinbondada/clarity-html.git"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}
